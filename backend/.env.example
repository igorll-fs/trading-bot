# =============================================================================
# TradingBot Enterprise — Environment Configuration
# =============================================================================
# Copy this file to backend/.env and fill in your credentials.
# NEVER commit backend/.env to version control — it's in .gitignore.
# =============================================================================

# --- EXCHANGE SELECTOR --------------------------------------------------------
# Supported: binance, kraken, coinbase, kucoin
EXCHANGE=binance

# --- BINANCE API --------------------------------------------------------------
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=false

# --- KRAKEN API ---------------------------------------------------------------
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# --- PAPER TRADING ------------------------------------------------------------
PAPER_TRADE=true
PAPER_TRADE_BALANCE=8000.0

# --- MONGODB (Required) -------------------------------------------------------
MONGO_URL=mongodb://localhost:27017
DB_NAME=trading_bot

# --- TELEGRAM NOTIFICATIONS ---------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- TRADING SETTINGS ---------------------------------------------------------
CAPITAL_INICIAL=1000.0
MAX_POSITIONS=2
RISK_PER_TRADE=0.005
RISK_PERCENTAGE=0.5

# --- CORS --------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# --- OLLAMA / AI RISK ADVISOR (Optional) -------------------------------------
LLM_RISK_ADVISOR_ENABLED=false

# --- MAINNET PARAMETERS ------------------------------------------------------
API_LATENCY_THRESHOLD=8.0
STRATEGY_MIN_SIGNAL_STRENGTH=80
RISK_TRAILING_ACTIVATION=0.75
RISK_MAX_HOLD_HOURS=4
SELECTOR_MIN_QUOTE_VOLUME=100000
SELECTOR_MIN_CHANGE_PERCENT=0.5
SELECTOR_TRENDING_POOL_SIZE=20
LEARNING_MIN_TRADES=15
LEARNING_MIN_CONFIDENCE=0.60
SYMBOL_SL_COOLDOWN_MINUTES=60
