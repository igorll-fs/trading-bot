# =============================================================================
# TradingBot Enterprise — Environment Configuration
# =============================================================================
# Copy this file to backend/.env and fill in your credentials.
# NEVER commit backend/.env to version control — it's in .gitignore.
# =============================================================================

# --- BINANCE API (Required) --------------------------------------------------
# Get keys from https://testnet.binance.vision (Testnet) or
#   https://www.binance.com/en/my/settings/api-management (Mainnet)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
USE_TESTNET=true

# --- MONGODB (Required) ------------------------------------------------------
MONGO_URL=mongodb://localhost:27017
DB_NAME=trading_bot

# --- TELEGRAM NOTIFICATIONS (Required) ---------------------------------------
# Create a bot with @BotFather on Telegram, then get your chat ID via
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- TRADING SETTINGS --------------------------------------------------------
CAPITAL_INICIAL=1000.0
MAX_POSITIONS=2                    # Simultaneous positions allowed
RISK_PER_TRADE=0.005               # Decimal (0.5%)
RISK_PERCENTAGE=0.5                # Percent — BotConfig reads THIS value
TRADING_TIME_FILTER=false          # Restrict trading to specific hours

# --- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- OLLAMA / AI RISK ADVISOR (Optional) ------------------------------------
# Disable if Ollama is not installed or Mistral model is not pulled.
LLM_RISK_ADVISOR_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# --- TESTNET OPTIMIZATIONS ---------------------------------------------------
# These values are tuned for Binance Spot Testnet (lower volume, higher latency).
# Adjust upward for mainnet.
SELECTOR_MIN_QUOTE_VOLUME=1000     # Min 24h quote volume (testnet: 1000, mainnet: 100000)
SELECTOR_MIN_CHANGE_PERCENT=0.3    # Min 24h price change %
SELECTOR_TRENDING_POOL_SIZE=15     # Number of pairs in the trending pool
API_LATENCY_THRESHOLD=10.0         # Max seconds per API call before circuit breaker
STRATEGY_MIN_SIGNAL_STRENGTH=70    # Unified score threshold (mainnet: 80)
RISK_TRAILING_ACTIVATION=0.50      # Trailing stop activation threshold
RISK_MAX_HOLD_HOURS=8              # Max hold time per position
LEARNING_MIN_TRADES=5              # Min trades before ML auto-tuning (mainnet: 15)
LEARNING_MIN_CONFIDENCE=0.70       # Min ML confidence to apply adjustments
SYMBOL_SL_COOLDOWN_MINUTES=30      # Minutes before re-buying a stopped-out symbol
